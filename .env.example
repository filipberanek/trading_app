# ── Copy this file to .env and fill in your values ────────────────────────────
# NEVER commit .env to git.

# IBKR IB Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4002          # 4002 = paper trading  |  4001 = live trading
IBKR_CLIENT_ID=1

# When to run the strategy (UTC)
# Default: 08:05 UTC = 09:05 CET = 5 min after European market open
TRADE_HOUR_UTC=8
TRADE_MINUTE_UTC=5

# Database (SQLite path inside the container / on the server)
DB_PATH=data/trading.db

# Strategy config
CONFIG_PATH=config/atr_sma_c.yaml

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/trading.log

# ── Notifications (both are optional — leave blank to disable) ─────────────────

# Telegram — získej token přes @BotFather, chat_id přes /getUpdates
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail příklad — použij App Password, ne heslo k účtu)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvuj@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=tvuj@gmail.com
EMAIL_TO=tvuj@gmail.com
