# Zkopírujte tento soubor jako .env a vyplňte hodnoty
# NIKDY necommitujte .env do gitu!

# IB Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# Trading mode: paper nebo live
TRADING_MODE=paper

# Risk management
MAX_POSITION_SIZE_PCT=0.05      # Max 5% portfolia na jednu pozici
MAX_DAILY_LOSS_USD=500          # Stop trading při denní ztrátě $500

# Alerting (volitelné)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
